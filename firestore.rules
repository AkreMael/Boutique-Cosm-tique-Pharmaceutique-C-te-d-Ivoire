rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default catch-all denies all access
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth verification helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn(); // Simplified for safe sandbox deployment. In production, check role in user doc or claims.
    }

    // 1. Users collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // 2. Modules collection
    match /modules/{moduleId} {
      allow read, write: if true;
    }

    // 3. Items collection
    match /items/{itemId} {
      allow read, write: if true;
    }

    // 4. Orders collection
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // 5. Messages collection
    match /messages/{messageId} {
      allow read, write: if true;
    }

    // 6. UserModuleAccess collection
    match /userModuleAccess/{accessId} {
      allow read, write: if true;
    }

    // 7. ActivityLogs collection
    match /activityLogs/{logId} {
      allow read, write: if true;
    }

    // 8. Notifications collection
    match /notifications/{notifId} {
      allow read, write: if true;
    }

    // Supporting legacy collections
    match /products/{prodId} {
      allow read, write: if true;
    }

    match /categories/{catId} {
      allow read, write: if true;
    }

    match /chats/{chatId} {
      allow read, write: if true;
    }

    match /chats/{chatId}/messages/{msgId} {
      allow read, write: if true;
    }
  }
}
