rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default catch-all denies all access
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth verification helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn(); // Simplified for safe sandbox deployment. In production, check role in user doc or claims.
    }

    // 1. Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // 2. Modules collection
    match /modules/{moduleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Items collection
    match /items/{itemId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // 4. Orders collection
    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // 5. Messages collection
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // 6. UserModuleAccess collection
    match /userModuleAccess/{accessId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 7. ActivityLogs collection
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // 8. Notifications collection
    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // Supporting legacy collections
    match /products/{prodId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /chats/{chatId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /chats/{chatId}/messages/{msgId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
